{
  "expo": {
    "name": "Sumi",
    "slug": "sumi-rebuild",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios-icon.png",
    "scheme": "sumirebuild",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.sumisupabase",
      "icon": "./assets/images/ios-icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Sumi uses your camera so you can add profile pictures and share images in the app."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sumi-android-icon.png",
        "backgroundColor": "#F6F7EB"
      },
      "package": "com.anonymous.sumisupabase",
      "versionCode": 7
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/sumi-splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#393E41"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "urlScheme": "sumirebuild"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1b98754-df28-4059-9f13-d17aa786933d"
      }
    }
  }
}
